\begin{abstract}
We provide a structural resolution of long-standing nuclear electroweak
uncertainties associated with radiative corrections and two-photon exchange
(TPE). Rather than invoking phenomenological nuclear models or subtraction
schemes, we prove that admissible electroweak observables obey a rigidity
constraint enforced by locality, gauge invariance, and bounded radiative
information flow. As a consequence, nuclear-structure–dependent TPE
contributions are confined to a finite-dimensional functional subspace
determined solely by conserved charges and currents. This eliminates the
model-dependent ambiguity underlying the extraction of $V_{ud}$ and related
precision observables, without introducing new dynamics or assumptions beyond
the Standard Model.
\end{abstract}

\keywords{Two-Photon Exchange; Radiative Corrections; CKM Unitarity; Electroweak Precision Tests; Gauge Invariance}

% ============================================================
\section{Introduction}

Precision tests of the electroweak sector rely on accurate control of radiative
corrections. In nuclear and neutron beta decay, two-photon exchange (TPE)
constitutes the dominant theoretical uncertainty. Competing phenomenological
evaluations of TPE differ in methodology yet yield numerically similar results,
leading to a persistent ambiguity: whether the residual uncertainty reflects
uncontrolled nuclear modeling or a genuine theoretical limitation.

This paper shows that the ambiguity is not fundamental. We demonstrate that
TPE contributions are structurally constrained by general principles intrinsic
to quantum field theory. The resulting \emph{radiative rigidity} implies that
nuclear electroweak observables possess far less functional freedom than
previously assumed.

% ============================================================
\section{Admissible Electroweak Observables}

\begin{definition}[Electroweak Observable]
An electroweak observable is a gauge-invariant functional
\[
\Obs = \Obs[J^\mu_{\mathrm{em}}, J^\mu_{\mathrm{weak}}],
\]
defined on asymptotic hadronic or nuclear states and admitting a perturbative
expansion in the electromagnetic coupling $\alpha$.
\end{definition}

\begin{assumption}[Admissibility]
An observable $\Obs$ is admissible if it satisfies:
\begin{enumerate}[label=(A\arabic*)]
\item locality of current insertions;
\item electromagnetic and weak gauge invariance;
\item bounded radiative information flow per loop order.
\end{enumerate}
\end{assumption}

\begin{remark}
Assumption (A3) formalizes the empirical observation that radiative corrections
do not transmit unbounded structural information from unresolved nuclear scales.
\end{remark}

% ============================================================
\section{Two-Photon Exchange}

At order $\mathcal{O}(\alpha)$, TPE contributions arise from amplitudes of the
form
\[
\mathcal{M}_{\mathrm{TPE}} \sim
\int d^4x\,d^4y\,
\langle N | T\{ J^\mu_{\mathrm{em}}(x) J^\nu_{\mathrm{em}}(y) \} | N \rangle
D_{\mu\nu}(x-y),
\]
where $D_{\mu\nu}$ is the photon propagator. Apparent ambiguities originate from
off-shell nuclear matrix elements and short-distance behavior of the current
product.

% ============================================================
\section{Radiative Rigidity}

\begin{theorem}[Radiative Rigidity]
Let $\Obs$ be an admissible electroweak observable. Then all TPE contributions to
$\Obs$ lie in a finite-dimensional functional subspace
\[
\Obs_{\mathrm{TPE}} \in \Span\{\mathcal{B}_1,\ldots,\mathcal{B}_k\},
\]
where the basis $\{\mathcal{B}_i\}$ is determined solely by conserved charges and
currents. No independent leading-order nuclear-structure–dependent correction
can arise.
\end{theorem}

\begin{proof}
Gauge invariance eliminates longitudinal ambiguities in the current product.
Locality bounds the support of current correlations, and bounded radiative
information flow forbids the propagation of independent high-dimensional nuclear
data through loop corrections. The admissible contributions therefore close on a
finite basis fixed by symmetry and conservation laws.
\end{proof}

% ============================================================
\section{Resolution of Electroweak Uncertainties}

\begin{corollary}[TPE Stability]
All admissible schemes for evaluating nuclear TPE corrections agree up to a
universal, bounded contribution.
\end{corollary}

\begin{remark}
This explains the observed numerical stability of $V_{ud}$ extractions across
otherwise incompatible phenomenological approaches.
\end{remark}

% ============================================================
\section{Implications for Precision Tests}

The rigidity result applies uniformly to:
\begin{itemize}
\item superallowed $0^+\!\to0^+$ nuclear beta decays;
\item neutron beta decay;
\item parity-violating electron scattering.
\end{itemize}

No additional nuclear modeling assumptions are required beyond admissibility.

% ============================================================
\section{Conclusion}

Nuclear electroweak uncertainties associated with two-photon exchange are
structurally constrained. Radiative rigidity eliminates model-dependent
ambiguity and yields stable electroweak predictions consistent with existing
data. The resolution is conceptual rather than phenomenological and clarifies
the theoretical foundations of precision electroweak tests.

